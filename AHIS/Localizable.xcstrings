    "onboarding.permissions.denied" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Standortberechtigung wurde verweigert. Winch Pilot benötigt GPS um zu funktionieren. Bitte aktivieren Sie es in den Einstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Location permission was denied. Winch Pilot needs GPS to work. Please enable it in Settings."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il permesso di localizzazione è stato negato. Winch Pilot ha bisogno del GPS per funzionare. Abilitalo nelle Impostazioni."
          }
        }
      }
    },
    "onboarding.permissions.gps.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Misst die Bodengeschwindigkeit und die verbleibende Startbahnlänge während des Windenstarts. Ohne GPS kann die App nicht funktionieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Measures ground speed and runway distance during the winch launch. Without GPS the app cannot function."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Misura la velocità al suolo e la distanza dalla pista durante il lancio al verricello. Senza GPS l'app non può funzionare."
          }
        }
      }
    },
    "onboarding.permissions.gps.title" : {
