    "onboarding.permissions.motion.body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Betreibt den künstlichen Horizont und verbessert die Geschwindigkeitsgenauigkeit zwischen GPS-Messungen mittels Beschleunigungsmesser bei 50Hz."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Powers the artificial horizon and improves speed accuracy between GPS readings using the accelerometer at 50Hz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alimenta l'orizzonte artificiale e migliora la precisione della velocità tra le letture GPS usando l'accelerometro a 50Hz."
          }
        }
      }
    },
